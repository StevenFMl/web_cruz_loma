---
import Layout from '../layouts/Layout.astro';
import AgeVerification from '../components/AgeVerification.jsx';
import Navbar from '../components/Navbar.jsx';
import HeroSection from '../components/HeroSection.jsx';
import OurHistory from '../components/OurHistory.jsx';
import OurBeers from '../components/OurBeers.jsx';
import CraftProcess from '../components/CraftProcess.jsx';
import Footer from '../components/Footer.jsx';
---

<Layout title="Cruz Loma | Cervecería Artesanal Premium">
  <!-- Age Gate runs on client-only to avoid SSR mismatch with sessionStorage -->
  <AgeVerification client:only="react" />

  <!-- Sticky Navbar -->
  <Navbar client:load />

  <main>
    <HeroSection client:load />
    <OurHistory client:visible />
    <OurBeers client:visible />
    <section id="proceso">
      <CraftProcess client:visible />
    </section>
  </main>

  <section id="footer">
    <Footer client:idle />
  </section>
</Layout>
