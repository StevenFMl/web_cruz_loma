---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Cruz Loma Cerveza Artesanal." } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts: Rye for vintage wood-type logo/titles, Inter for body -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Rye&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    
    <title>{title}</title>
  </head>
  <body class="bg-[#1a1512] font-sans text-stone-300 antialiased overflow-x-hidden selection:bg-amber-600/30 selection:text-amber-200">
    <slot />
  </body>
</html>

<style is:global>
  /* Custom Font Classes */
  .font-vintage {
    font-family: 'Rye', serif;
  }
  .font-sans {
    font-family: 'Inter', sans-serif;
  }
</style>
