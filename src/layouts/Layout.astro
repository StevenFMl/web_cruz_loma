---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Cruz Loma Cerveza Artesanal." } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Typography requested: Ganache, Gotham Bold, Source Serif Variable -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Montserrat:wght@700&family=Source+Serif+4:ital,opsz,wght@0,8..60,200..900;1,8..60,200..900&display=swap" rel="stylesheet">
    
    <title>{title}</title>
  </head>
  <body class="bg-[#1a1512] font-sans text-stone-300 antialiased overflow-x-hidden selection:bg-amber-600/30 selection:text-amber-200">
    <slot />
  </body>
</html>

<style is:global>
  /* Custom Font Classes matching requirements */
  .font-ganache {
    font-family: 'Ganache', 'Pacifico', cursive;
  }
  .font-gotham {
    font-family: 'Gotham Bold', 'Gotham', 'Montserrat', sans-serif;
    font-weight: bold;
  }
  .font-source {
    font-family: 'Source Serif Variable', 'Source Serif 4', serif;
  }
</style>
